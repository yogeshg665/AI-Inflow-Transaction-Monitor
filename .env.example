# =============================================================================
# AI Inflow Transaction Monitor - Environment Variables
# Copy this file to .env and customize. All values are optional; the engine
# runs fully deterministically with no provider configured.
# =============================================================================

# Logging verbosity: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Decision policy overrides (0-100). Leave unset to use config.yaml values.
# RISK_FLAG_THRESHOLD=75
# RISK_REVIEW_THRESHOLD=45

# -----------------------------------------------------------------------------
# Optional narrative LLM. The score and the decision are always deterministic;
# a model may only enrich the human-readable narrative. Leave provider as
# "none" to run without any network access or credentials.
# -----------------------------------------------------------------------------
LLM_PROVIDER=none
LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=
# LLM_API_BASE=
# LLM_API_VERSION=
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=30
